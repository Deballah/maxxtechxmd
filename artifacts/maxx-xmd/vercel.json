{
  "buildCommand": "npm install -g pnpm@10.11.0 && cd ../.. && pnpm install --no-frozen-lockfile && pnpm --filter @workspace/maxx-xmd build",
  "outputDirectory": "dist/public",
  "installCommand": "echo 'install handled in buildCommand'",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://maxx-xmd-bot-6890ef3ee355.herokuapp.com/api/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
